* ORD.PROCESS
* Order Processing Subroutine
* Handles main order validation and inventory update
* Called by: MAIN.MENU, BATCH.ORDERS
*
SUBROUTINE ORD.PROCESS(ORDER.ID, STATUS)

OPEN 'ORDERS' TO ORDERS.FILE ELSE
   STATUS = 'ERROR'
   RETURN
END

OPEN 'INVENTORY' TO INV.FILE ELSE
   CLOSE ORDERS.FILE
   STATUS = 'ERROR'
   RETURN
END

READU ORDER.REC FROM ORDERS.FILE, ORDER.ID LOCKED
   GOSUB HANDLE.LOCK
END ELSE
   STATUS = 'NOT.FOUND'
   CLOSE ORDERS.FILE
   CLOSE INV.FILE
   RETURN
END

* Validate the order
CALL ORD.VALIDATE(ORDER.ID, STATUS)

IF STATUS = 'VALID' THEN
   CALL INV.UPDATE(ORDER.REC, STATUS)
END

WRITE ORDER.REC ON ORDERS.FILE, ORDER.ID

CLOSE ORDERS.FILE
CLOSE INV.FILE

RETURN

HANDLE.LOCK:
* Handle record lock contention
   STATUS = 'LOCKED'
   RETURN
