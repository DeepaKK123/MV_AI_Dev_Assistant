* ORD.VALIDATE
* Validates order header data
* Called by: ORD.PROCESS
*
SUBROUTINE ORD.VALIDATE(ORDER.ID, STATUS)

OPEN 'CUSTOMERS' TO CUST.FILE ELSE
   STATUS = 'ERROR'
   RETURN
END

READ CUST.REC FROM CUST.FILE, ORDER.ID<2> ELSE
   STATUS = 'INVALID.CUSTOMER'
   CLOSE CUST.FILE
   RETURN
END

IF CUST.REC<5> = 'ACTIVE' THEN
   STATUS = 'VALID'
END ELSE
   STATUS = 'INACTIVE.CUSTOMER'
END

CLOSE CUST.FILE
RETURN
